# Copy to .env and fill in your keys — see docs/PRE_LAUNCH.md for full setup
# Vite only exposes vars prefixed with VITE_ to the browser bundle

# Alpaca — paper trading dashboard: https://app.alpaca.markets/paper-trading
VITE_ALPACA_API_KEY_ID=your_paper_key_id_here
VITE_ALPACA_API_SECRET_KEY=your_paper_secret_here
VITE_ALPACA_BASE_URL=https://paper-api.alpaca.markets
VITE_ALPACA_DATA_URL=https://data.alpaca.markets

# Polygon.io (optional, for additional market data)
VITE_POLYGON_API_KEY=your_polygon_key_here

# Wheel-strategy analysis backend (WheelStrategy.Api)
VITE_API_BASE_URL=http://localhost:5099

# The following are server-side only and do NOT need VITE_ prefix:
# IBKR_HOST, IBKR_PORT, IBKR_CLIENT_ID
# ETRADE_CONSUMER_KEY, ETRADE_CONSUMER_SECRET
# ANTHROPIC_API_KEY
