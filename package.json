{
  "name": "wheel-strategy",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:api": "openapi-typescript ./backend/WheelStrategy.Api/WheelStrategy.Api.json -o ./src/api/generated/analysis.ts",
    "check:api": "npm run gen:api && git diff --exit-code src/api/generated backend/WheelStrategy.Api/WheelStrategy.Api.json"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.9"
  }
}
